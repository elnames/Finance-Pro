generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = "sqlserver://100.117.249.82:1433;database=finanzas_pro_db;user=sa;password=Interestelar01!;encrypt=true;trustServerCertificate=true;"
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  nombre            String
  createdAt         DateTime           @default(now())
  plan              String             @default("FREE")
  role              String             @default("USER")
  accounts          Account[]
  categories        Category[]
  recurringExpenses RecurringExpense[]
  budgets          Budget[]
}

model Account {
  id           Int           @id @default(autoincrement())
  nombre       String
  saldoActual  Float         @default(0)
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Category {
  id           Int           @id @default(autoincrement())
  nombre       String
  tipo         String
  colorHex     String?
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  monto       Float
  tipo        String
  fecha       DateTime @default(now())
  descripcion String
  accountId   Int
  categoryId  Int
  account     Account  @relation(fields: [accountId], references: [id], onUpdate: NoAction)
  category    Category @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
}

model RecurringExpense {
  id          Int     @id @default(autoincrement())
  descripcion String
  monto       Float
  diaDelMes   Int
  isActive    Boolean @default(true)
  userId      Int
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id         Int      @id @default(autoincrement())
  monto      Float
  mes        Int
  anio       Int
  categoryId Int
  userId     Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
