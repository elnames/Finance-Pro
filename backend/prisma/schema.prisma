  provider = "sqlserver"
  url      = "sqlserver://100.117.249.82:1433;database=finanzas_pro_db;user=sa;password=Interestelar01!;encrypt=true;trustServerCertificate=true;"
}

// SQL Server no soporta Enums nativos en Prisma, usamos String
// tipos: INGRESO, GASTO

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String
  role      String   @default("USER") // USER, ADMIN
  plan      String   @default("FREE") // FREE, PREMIUM, ELITE
  createdAt DateTime @default(now())
  
  accounts          Account[]
  recurringExpenses RecurringExpense[]
  categories        Category[]
}

model Account {
  id           Int           @id @default(autoincrement())
  nombre       String
  saldoActual  Float         @default(0)
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Category {
  id          Int             @id @default(autoincrement())
  nombre      String
  tipo        String          // INGRESO o GASTO
  colorHex    String?
  userId      Int
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          Int             @id @default(autoincrement())
  monto       Float
  tipo        String          // INGRESO o GASTO
  fecha       DateTime        @default(now())
  descripcion String
  accountId   Int
  account     Account         @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categoryId  Int
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model RecurringExpense {
  id          Int     @id @default(autoincrement())
  descripcion String
  monto       Float
  diaDelMes   Int     
  isActive    Boolean @default(true)
  userId      Int
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
