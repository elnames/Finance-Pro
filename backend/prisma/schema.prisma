generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  nombre            String
  createdAt         DateTime           @default(now())
  plan              String             @default("FREE")
  role              String             @default("USER")
  accounts          Account[]
  categories        Category[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]
  payments          Payment[]
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    Int
  plan      String
  amount    Int
  buyOrder  String   @unique
  status    String   @default("SUCCESS")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id           Int           @id @default(autoincrement())
  nombre       String
  saldoActual  Decimal       @default(0)
  userId       Int
  deletedAt    DateTime?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Category {
  id           Int           @id @default(autoincrement())
  nombre       String
  tipo         String
  colorHex     String?
  userId       Int
  deletedAt    DateTime?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id          Int       @id @default(autoincrement())
  monto       Float
  tipo        String
  fecha       DateTime  @default(now())
  descripcion String
  accountId   Int
  categoryId  Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  account     Account   @relation(fields: [accountId], references: [id], onUpdate: NoAction)
  category    Category  @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
}

model RecurringExpense {
  id          Int     @id @default(autoincrement())
  descripcion String
  monto       Float
  tipo        String  @default("GASTO")
  diaDelMes   Int
  isActive    Boolean @default(true)
  userId      Int
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id         Int      @id @default(autoincrement())
  monto      Float
  mes        Int
  anio       Int
  categoryId Int
  userId     Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([categoryId, mes, anio])
}
